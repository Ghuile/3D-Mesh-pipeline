# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files
*.zip binary
*.tar.gz binary
*.pth binary
*.pt binary
*.pkl binary
*.npz binary
